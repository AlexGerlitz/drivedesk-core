{
  "schema_version": 1,
  "state_model": "public_opentofu_desired_state",
  "data_profile": "synthetic_fake_data",
  "source": {
    "iac_stack": "infra/opentofu/public",
    "plan_summary": "infra/opentofu/public/plan-summary.sanitized.json",
    "revision": "iac-plan-2026-06-18"
  },
  "environments": [
    "build",
    "staging",
    "canary",
    "production"
  ],
  "components": {
    "network_boundary": {
      "status": "required",
      "controls": [
        "public_ingress_separated",
        "private_runtime_not_public",
        "network_policies_required"
      ]
    },
    "kubernetes_runtime": {
      "status": "required",
      "workloads": [
        "api",
        "worker",
        "migration_job"
      ]
    },
    "gitops_controller": {
      "status": "required",
      "sync_mode": "reviewed_gitops_changes"
    },
    "observability": {
      "status": "required",
      "metrics_required": true,
      "logs_required": true,
      "log_retention_days": 14
    },
    "backup_storage": {
      "status": "required",
      "encrypted": true,
      "immutability_required": true,
      "restore_drill_required": true
    },
    "secrets_boundary": {
      "status": "required",
      "external_secret_manager_required": true,
      "secret_values_excluded": true
    }
  },
  "state_backend": {
    "encrypted_state_required": true,
    "locking_required": true,
    "public_backend_config_included": false,
    "secrets_in_state_allowed": false
  },
  "redaction": {
    "paths_included": false,
    "hostnames_included": false,
    "addresses_included": false,
    "credentials_included": false,
    "raw_logs_included": false,
    "production_data_included": false
  }
}
