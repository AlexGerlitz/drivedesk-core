{
  "schema_version": 1,
  "check": "public_gitops_layout",
  "data_profile": "synthetic_demo_data",
  "delivery_model": "argocd_gitops",
  "gitops": {
    "path": "infra/gitops",
    "controller": "argocd",
    "chart_path": "infra/helm/drivedesk-core",
    "environments": ["build", "staging", "canary", "production"]
  },
  "checks": {
    "gitops_files_present": true,
    "argocd_project_present": true,
    "argocd_applications_present": true,
    "public_repo_source_present": true,
    "helm_chart_path_referenced": true,
    "environment_value_files_referenced": true,
    "environment_overlays_present": true,
    "runtime_secret_refs_present": true,
    "staged_promotion_order_present": true,
    "evidence_gates_referenced": true,
    "private_markers_absent": true,
    "production_data_touched": false
  },
  "redaction": {
    "paths_included": false,
    "hostnames_included": false,
    "addresses_included": false,
    "credentials_included": false,
    "raw_logs_included": false,
    "production_data_included": false
  }
}
